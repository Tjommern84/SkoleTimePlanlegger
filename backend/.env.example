DATABASE_URL=sqlite:///./timetable.db
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=lise@example.com,colleague@example.com
SESSION_SECRET=change-me

# OAuth redirect target: must exactly match an Authorized redirect URI
# registered in Google Cloud Console. Locally this is the backend itself.
OAUTH_REDIRECT_BASE_URL=http://localhost:8123
# Where the browser is sent after login/logout -- the frontend's origin.
FRONTEND_URL=http://localhost:5173
# Set to true only in production (Render): enables CORS with credentials
# for the Vercel frontend origin, and switches the session cookie to
# SameSite=None; Secure (required for cross-site cookies over HTTPS).
IS_PRODUCTION=false
